# Copy this file to .env and fill in what you need. Both are optional —
# each feature they gate reports itself as "not enabled" without one.

# URLhaus malware-hosting check (app/checks/abuse.py). Free key:
# https://auth.abuse.ch/
ABUSECH_AUTH_KEY=

# Lets you toggle a seller's "verified" badge via
#   POST /api/admin/users/{id}/verify   header: X-Admin-Token: <this value>
# Pick any long random string. Leave blank to disable the endpoint (404).
ADMIN_TOKEN=
